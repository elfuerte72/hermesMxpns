# Copy to .env and fill real values. NEVER commit .env.

# Local infra
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hermes_deployer
REDIS_URL=redis://localhost:6379

# Hostinger operator token (from hPanel -> Profile -> API). ROTATE before production.
HOSTINGER_API_TOKEN=

# Telegram entry-bot token (from @BotFather)
BOT_TOKEN=

# Entry bot transport: false = long polling (dev), true = webhook (prod, needs public BACKEND_URL)
BOT_USE_WEBHOOK=false

# TMA initData freshness window in seconds (default 86400 = 24h)
TMA_AUTH_MAX_AGE_SECONDS=86400

# AES-256-GCM key, 32-byte hex (generate: openssl rand -hex 32)
ENCRYPTION_KEY=

# Public URLs (BACKEND_URL must be HTTPS for the Telegram bot webhook)
BACKEND_URL=http://localhost:3000
MINI_APP_URL=http://localhost:5173

# Mock Hostinger in dev; set false only at checkpoints with explicit approval
DRY_RUN=true

# Run the in-process BullMQ deploy worker (set false for an API-only node)
DEPLOY_WORKER_ENABLED=true

# Reconciliation cron: delete orphan VMs instead of only alerting (dangerous)
RECONCILE_DELETE_ORPHANS=false

# Phase 6 — Tribute subscription gating: id of the private "Hermes" channel whose
# membership (managed by @tribute) is the source of truth for an active subscription.
# entry-bot must be an admin of this channel for getChatMember / chat_member updates.
# Optional in dev (unset → subscription checks return 'none'); required for prod billing.
# SUBSCRIPTION_CHANNEL_ID=-1001234567890

# Phase 6 — OpenRouter Management API (operator secret from OpenRouter dashboard,
# distinct from normal API keys). Creates per-user spend-capped keys (§23.3).
# Required to actually provision agents; unset in dev → key calls throw.
OPENROUTER_MANAGEMENT_KEY=

# Per-user managed-key spend cap (USD) and reset cadence (§23.5: $40 monthly).
OPENROUTER_KEY_LIMIT_USD=40
OPENROUTER_KEY_LIMIT_RESET=monthly

# Markup added on top of a token topup (§23.5: +25% beats the 10% Tribute cut).
OPENROUTER_TOPUP_MARKUP_PERCENT=25

# Fixed topup tiers — JSON: [{"amount_usd":10,"channel_id":"-100...","subscribe_url":"https://t.me/tribute/..."}, ...]
# Each tier is a private Tribute-managed channel; membership (getChatMember) gates the
# raiseLimit. The entry-bot must be an admin of every tier channel. Leave empty in dev.
# TOPUP_TIERS=[]

# Days an expired subscription stays frozen (key disabled) before the agent is auto-removed.
SUBSCRIPTION_GRACE_DAYS=7

# Serve the built Mini App from the backend at /app (single-origin prod).
# Point at the frontend build output; leave unset to disable.
# SERVE_FRONTEND_DIR=/app/apps/frontend/dist
